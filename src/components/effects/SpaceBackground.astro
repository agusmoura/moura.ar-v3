---
interface Props {
  // Stars Background props
  starDensity?: number;
  allStarsTwinkle?: boolean;
  twinkleProbability?: number;
  minTwinkleSpeed?: number;
  maxTwinkleSpeed?: number;
  starsColor?: string;

  // Shooting Stars props
  shootingStarsEnabled?: boolean;
  minSpeed?: number;
  maxSpeed?: number;
  minDelay?: number;
  maxDelay?: number;
  starColor?: string;
  trailColor?: string;
  starWidth?: number;
  starHeight?: number;

  // Background props
  backgroundColor?: string | null;

  // Gravity props
  gravityEnabled?: boolean;
  gravityStrength?: number;
  gravityX?: number | null; // null = center
  gravityY?: number | null; // null = center

  // Mouse Gravity props
  mouseGravityEnabled?: boolean;
  mouseGravityStrength?: number;
  mouseGravityRadius?: number;
}

const {
  // Stars Background defaults
  starDensity = 0.00015,
  allStarsTwinkle = true,
  twinkleProbability = 0.7,
  minTwinkleSpeed = 0.5,
  maxTwinkleSpeed = 1,
  starsColor = '#ffffff',

  // Shooting Stars defaults
  shootingStarsEnabled = true,
  minSpeed = 15,
  maxSpeed = 30,
  minDelay = 1200,
  maxDelay = 4200,
  starColor = '#9E00FF',
  trailColor = '#2EB9DF',
  starWidth = 10,
  starHeight = 1,

  // Background defaults
  backgroundColor = '#000',

  // Gravity defaults
  gravityEnabled = true,
  gravityStrength = 8000,
  gravityX = null,
  gravityY = null,

  // Mouse Gravity defaults
  mouseGravityEnabled = true,
  mouseGravityStrength = 0.6,
  mouseGravityRadius = 0.15,
} = Astro.props;
---

<space-background
  transition:name="space-background"
  data-config={JSON.stringify({
    stars: {
      starDensity,
      allStarsTwinkle,
      twinkleProbability,
      minTwinkleSpeed,
      maxTwinkleSpeed,
      starsColor,
    },
    shootingStars: {
      enabled: shootingStarsEnabled,
      minSpeed,
      maxSpeed,
      minDelay,
      maxDelay,
      starColor,
      trailColor,
      starWidth,
      starHeight,
    },
    backgroundColor,
    gravity: {
      enabled: gravityEnabled,
      strength: gravityStrength,
      x: gravityX,
      y: gravityY,
    },
    mouseGravity: {
      enabled: mouseGravityEnabled,
      strength: mouseGravityStrength,
      radius: mouseGravityRadius,
    },
  })}
>
  <canvas class="space-canvas" aria-hidden="true"></canvas>
</space-background>

<script>
  interface Star {
    x: number;
    y: number;
    radius: number;
    opacity: number;
    twinkleSpeed: number | null;
    twinklePhase: number;
  }

  interface ShootingStar {
    x: number;
    y: number;
    angle: number;
    speed: number;
    length: number;
    opacity: number;
    active: boolean;
    trail: Array<{ x: number; y: number; opacity: number }>;
    maxTrailLength: number;
  }

  interface Config {
    stars: {
      starDensity: number;
      allStarsTwinkle: boolean;
      twinkleProbability: number;
      minTwinkleSpeed: number;
      maxTwinkleSpeed: number;
      starsColor: string;
    };
    shootingStars: {
      enabled: boolean;
      minSpeed: number;
      maxSpeed: number;
      minDelay: number;
      maxDelay: number;
      starColor: string;
      trailColor: string;
      starWidth: number;
      starHeight: number;
    };
    backgroundColor: string | null;
    gravity: {
      enabled: boolean;
      strength: number;
      x: number | null;
      y: number | null;
    };
    mouseGravity: {
      enabled: boolean;
      strength: number;
      radius: number;
    };
  }

  class SpaceBackground extends HTMLElement {
    private config: Config;
    private canvas: HTMLCanvasElement;
    private ctx: CanvasRenderingContext2D | null;
    private stars: Star[] = [];
    private shootingStars: ShootingStar[] = [];
    private shootingStarPool: ShootingStar[] = [];
    private animationId: number | null = null;
    private resizeTimeout: number | null = null;
    private lastTime: number = 0;
    private nextShootingStarTime: number = 0;
    private width: number = 0;
    private height: number = 0;
    private dpr: number = 1;
    private shootingStarColors: { r: number; g: number; b: number };
    private trailColors: { r: number; g: number; b: number };
    private orbitContainer: Element | null = null;
    private orbitRect: DOMRect | null = null;
    private mouseX: number = -1000;
    private mouseY: number = -1000;
    private mouseGravityStrength: number;
    private mouseGravityRadius: number;
    private MAX_SHOOTING_STARS = 2;
    private frameCount = 0;
    private gravityCache: {
      coords: { x: number; y: number; width: number; height: number };
      lastUpdate: number;
    } | null = null;
    private lastMouseMove = 0;
    private MOUSE_THROTTLE = 16.67;
    private isLoading = true;
    private loadingProgress = 0;
    private fadeInProgress = 0;
    private totalStars = 0;
    private STARS_PER_BATCH = 200;
    private loadingStartTime = 0;
    private static globalInstance: SpaceBackground | null = null;
    private readonly STORAGE_KEY = 'space-background-state';
    private readonly STORAGE_VERSION = '1.0';

    constructor() {
      super();

      this.canvas = this.querySelector('.space-canvas') as HTMLCanvasElement;
      this.ctx = this.canvas?.getContext('2d', { alpha: false });

      // Set this as the global instance
      SpaceBackground.globalInstance = this;

      try {
        this.config = JSON.parse(this.dataset.config || '{}');
      } catch (e) {
        console.warn('Failed to parse space background config:', e);
        this.config = {
          stars: {
            starDensity: 0.00015,
            allStarsTwinkle: true,
            twinkleProbability: 0.7,
            minTwinkleSpeed: 0.5,
            maxTwinkleSpeed: 1,
            starsColor: '#ffffff',
          },
          shootingStars: {
            enabled: true,
            minSpeed: 10,
            maxSpeed: 30,
            minDelay: 1200,
            maxDelay: 4200,
            starColor: '#9E00FF',
            trailColor: '#2EB9DF',
            starWidth: 10,
            starHeight: 1,
          },
          backgroundColor: '#000',
          gravity: {
            enabled: true,
            strength: 8000,
            x: null,
            y: null,
          },
          mouseGravity: {
            enabled: true,
            strength: 0.6,
            radius: 0.15,
          },
        };
      }

      // Set mouse gravity values from config
      this.mouseGravityStrength = this.config.mouseGravity.strength;
      this.mouseGravityRadius = this.config.mouseGravity.radius;

      // Parse colors once
      this.shootingStarColors = this.hexToRgb(this.config.shootingStars.starColor);
      this.trailColors = this.hexToRgb(this.config.shootingStars.trailColor);

      this.setupBackground();
    }

    private isViewTransition(): boolean {
      return (
        document.documentElement.classList.contains('view-transition-active') ||
        // Fallback check for Astro's view transitions
        (document as any).startViewTransition !== undefined ||
        // Additional check for any transition state
        performance.now() - (window as any)._lastNavigationStart < 100
      );
    }

    private saveStateToStorage(): void {
      try {
        const state = {
          version: this.STORAGE_VERSION,
          timestamp: Date.now(),
          width: this.width,
          height: this.height,
          stars: this.stars,
          isLoading: this.isLoading,
          loadingProgress: this.loadingProgress,
          fadeInProgress: this.fadeInProgress,
          totalStars: this.totalStars,
          config: this.config,
        };
        sessionStorage.setItem(this.STORAGE_KEY, JSON.stringify(state));
      } catch (error) {
        console.warn('Failed to save space background state:', error);
      }
    }

    private loadStateFromStorage(): boolean {
      try {
        const stored = sessionStorage.getItem(this.STORAGE_KEY);
        if (!stored) return false;

        const state = JSON.parse(stored);

        // Check version compatibility
        if (state.version !== this.STORAGE_VERSION) {
          sessionStorage.removeItem(this.STORAGE_KEY);
          return false;
        }

        // Check if stored state is too old (more than 1 hour)
        const now = Date.now();
        if (now - state.timestamp > 3600000) {
          sessionStorage.removeItem(this.STORAGE_KEY);
          return false;
        }

        // Check if dimensions changed significantly (more than 20% difference)
        const widthDiff = Math.abs(this.width - state.width) / state.width;
        const heightDiff = Math.abs(this.height - state.height) / state.height;
        if (widthDiff > 0.2 || heightDiff > 0.2) {
          sessionStorage.removeItem(this.STORAGE_KEY);
          return false;
        }

        // Restore state
        this.stars = state.stars || [];
        this.isLoading = state.isLoading ?? false;
        this.loadingProgress = state.loadingProgress ?? 1;
        this.fadeInProgress = state.fadeInProgress ?? 1;
        this.totalStars = state.totalStars || this.stars.length;

        return true;
      } catch (error) {
        console.warn('Failed to load space background state:', error);
        sessionStorage.removeItem(this.STORAGE_KEY);
        return false;
      }
    }

    private copyStateFrom(instance: SpaceBackground): void {
      // Copy configuration and state
      this.config = instance.config;
      this.stars = instance.stars;
      this.shootingStars = instance.shootingStars;
      this.shootingStarPool = instance.shootingStarPool;
      this.isLoading = instance.isLoading;
      this.loadingProgress = instance.loadingProgress;
      this.fadeInProgress = instance.fadeInProgress;
      this.totalStars = instance.totalStars;
      this.loadingStartTime = instance.loadingStartTime;
      this.mouseGravityStrength = instance.mouseGravityStrength;
      this.mouseGravityRadius = instance.mouseGravityRadius;
      this.shootingStarColors = instance.shootingStarColors;
      this.trailColors = instance.trailColors;
      this.frameCount = instance.frameCount;
      this.lastTime = instance.lastTime;
      this.nextShootingStarTime = instance.nextShootingStarTime;

      // Get new canvas element and context
      this.canvas = this.querySelector('.space-canvas') as HTMLCanvasElement;
      this.ctx = this.canvas?.getContext('2d', { alpha: false });

      // Set this as the new global instance
      SpaceBackground.globalInstance = this;

      // Setup the new canvas with preserved state
      this.setupCanvasWithState();
    }

    connectedCallback(): void {
      // Setup background when element is connected to DOM
      this.setupBackground();
    }

    private hexToRgb(hex: string): { r: number; g: number; b: number } {
      const result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
      return result
        ? {
            r: parseInt(result[1], 16),
            g: parseInt(result[2], 16),
            b: parseInt(result[3], 16),
          }
        : { r: 255, g: 255, b: 255 };
    }

    private setupCanvasWithState(): void {
      if (!this.canvas || !this.ctx) return;

      // Canvas styles are handled by CSS now (position: fixed, etc.)
      this.canvas.style.opacity = '1';
      this.canvas.style.transition = 'opacity 1s ease-in-out';

      this.findOrbitContainer();
      this.setupMouseTracking();
      this.setupCanvas();

      // Continue animation from where we left off
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        window.addEventListener('resize', this.handleResize.bind(this));
        this.lastTime = performance.now();
        this.animateFrame();
      } else {
        this.renderStatic();
      }

      // Save the current state after canvas setup
      this.saveStateToStorage();
    }

    private setupBackground(): void {
      if (!this.canvas || !this.ctx) return;

      // Canvas styles are handled by CSS now (position: fixed, etc.)
      this.canvas.style.opacity = '1';
      this.canvas.style.transition = 'opacity 1s ease-in-out';

      this.findOrbitContainer();
      this.setupMouseTracking();
      this.setupCanvas();

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        this.initializeStars();
        this.renderStatic();
        this.finishLoading();
        return;
      }

      this.loadingStartTime = performance.now();
      this.initializeShootingStarPool();
      this.initializeStars();

      // Start animation immediately to show loader
      window.addEventListener('resize', this.handleResize.bind(this));
      this.lastTime = performance.now();
      this.animateFrame();

      // Start progressive loading after first render
      requestAnimationFrame(() => {
        this.startProgressiveLoading();
      });
    }

    private setupMouseTracking(): void {
      // Only set up mouse tracking if mouse gravity is enabled
      if (this.config.mouseGravity.enabled) {
        // Add event listeners
        window.addEventListener('mousemove', this.handleMouseMove);
        this.canvas.addEventListener('mouseleave', this.handleMouseLeave);
      }
    }

    private setupCanvas(): void {
      // Use viewport dimensions since canvas is position: fixed
      this.width = window.innerWidth;
      this.height = window.innerHeight;
      this.dpr = Math.min(window.devicePixelRatio || 1, 2); // Cap at 2 for performance

      this.canvas.width = this.width * this.dpr;
      this.canvas.height = this.height * this.dpr;

      if (this.ctx) {
        this.ctx.scale(this.dpr, this.dpr);
        // Set background once
        this.ctx.fillStyle = this.config.backgroundColor || '#000';
        this.ctx.fillRect(0, 0, this.width, this.height);
      }
    }

    private initializeStars(): void {
      // Try to load from storage first
      if (this.loadStateFromStorage()) {
        console.log('Loaded stars from storage:', this.stars.length);
        // If loaded from storage, we're not loading
        this.isLoading = false;
        this.loadingProgress = 1;
        this.fadeInProgress = 1;
        return;
      }

      // Generate new stars if no stored state
      const { starDensity } = this.config.stars;
      const area = this.width * this.height;
      this.totalStars = Math.floor(area * starDensity);
      this.stars = [];
      this.loadingProgress = 0;
      this.isLoading = true;
    }

    private startProgressiveLoading(): void {
      // If we already have stars from storage, skip loading
      if (this.stars.length > 0) {
        this.finishLoading();
        return;
      }

      // Ensure we show the loading state
      this.isLoading = true;
      this.loadingProgress = 0;

      // Add some initial stars immediately
      this.addInitialStars();
      this.loadNextStarBatch();
    }

    private addInitialStars(): void {
      const { allStarsTwinkle, twinkleProbability, minTwinkleSpeed, maxTwinkleSpeed } =
        this.config.stars;
      // Add 20 initial stars immediately visible
      for (let i = 0; i < 20; i++) {
        const shouldTwinkle = allStarsTwinkle || Math.random() < twinkleProbability;
        this.stars.push({
          x: Math.random() * this.width,
          y: Math.random() * this.height,
          radius: Math.random() * 0.8 + 1,
          opacity: Math.random() * 0.5 + 0.5,
          twinkleSpeed: shouldTwinkle
            ? minTwinkleSpeed + Math.random() * (maxTwinkleSpeed - minTwinkleSpeed)
            : null,
          twinklePhase: Math.random() * Math.PI * 2,
        });
      }
    }

    private loadNextStarBatch(): void {
      const { allStarsTwinkle, twinkleProbability, minTwinkleSpeed, maxTwinkleSpeed } =
        this.config.stars;
      const starsToAdd = Math.min(this.STARS_PER_BATCH, this.totalStars - this.stars.length);

      for (let i = 0; i < starsToAdd; i++) {
        const shouldTwinkle = allStarsTwinkle || Math.random() < twinkleProbability;
        this.stars.push({
          x: Math.random() * this.width,
          y: Math.random() * this.height,
          radius: Math.random() * 0.05 + 0.5,
          opacity: Math.random() * 0.5 + 0.5,
          twinkleSpeed: shouldTwinkle
            ? minTwinkleSpeed + Math.random() * (maxTwinkleSpeed - minTwinkleSpeed)
            : null,
          twinklePhase: Math.random() * Math.PI * 2,
        });
      }

      this.loadingProgress = this.stars.length / this.totalStars;

      if (this.stars.length < this.totalStars) {
        requestAnimationFrame(() => this.loadNextStarBatch());
      } else {
        this.finishLoading();
      }
    }

    private finishLoading(): void {
      this.isLoading = false;
      this.loadingProgress = 1;

      if (this.config.shootingStars.enabled) {
        this.scheduleNextShootingStar();
      }

      this.canvas.style.opacity = '1';

      setTimeout(() => {
        this.fadeInProgress = 1;
        // Save state after loading is complete
        this.saveStateToStorage();
      }, 100);
    }

    private initializeShootingStarPool(): void {
      // Pre-create shooting stars for object pooling
      const poolSize = 5;
      for (let i = 0; i < poolSize; i++) {
        this.shootingStarPool.push({
          x: 0,
          y: 0,
          angle: 0,
          speed: 0,
          length: this.config.shootingStars.starWidth,
          opacity: 1,
          active: false,
          trail: [],
          maxTrailLength: 10,
        });
      }
      this.shootingStarPool.push({
        x: 0,
        y: 0,
        angle: 0,
        speed: 0,
        length: this.config.shootingStars.starWidth,
        opacity: 1,
        active: false,
        trail: [],
        maxTrailLength: 10,
      });
    }

    private getShootingStar(): ShootingStar | null {
      // Get from pool or create new one
      let star = this.shootingStarPool.find((s) => !s.active);
      if (!star && this.shootingStarPool.length < 10) {
        star = {
          x: 0,
          y: 0,
          angle: 0,
          speed: 0,
          length: this.config.shootingStars.starWidth,
          opacity: 1,
          active: false,
          trail: [],
          maxTrailLength: 20,
        };
        this.shootingStarPool.push(star);
      }
      return star || null;
    }

    private scheduleNextShootingStar(): void {
      const { minDelay, maxDelay } = this.config.shootingStars;
      const delay = Math.random() * (maxDelay - minDelay) + minDelay;
      this.nextShootingStarTime = performance.now() + delay;
    }

    private createShootingStar(): void {
      if (this.shootingStars.length >= this.MAX_SHOOTING_STARS) return;

      const star = this.getShootingStar();
      if (!star) return;

      const { minSpeed, maxSpeed } = this.config.shootingStars;
      const side = Math.floor(Math.random() * 4);
      const offset = Math.random();

      // Set starting position based on side
      switch (side) {
        case 0: // Top
          star.x = offset * this.width;
          star.y = -50;
          star.angle = Math.PI / 4 + (Math.random() * Math.PI) / 2;
          break;
        case 1: // Right
          star.x = this.width + 50;
          star.y = offset * this.height;
          star.angle = (3 * Math.PI) / 4 + (Math.random() * Math.PI) / 2;
          break;
        case 2: // Bottom
          star.x = offset * this.width;
          star.y = this.height + 50;
          star.angle = (5 * Math.PI) / 4 + (Math.random() * Math.PI) / 2;
          break;
        case 3: // Left
          star.x = -50;
          star.y = offset * this.height;
          star.angle = (7 * Math.PI) / 4 + (Math.random() * Math.PI) / 2;
          break;
      }

      star.speed = minSpeed + Math.random() * (maxSpeed - minSpeed);
      star.opacity = 1;
      star.active = true;
      star.length = this.config.shootingStars.starWidth;
      star.trail = []; // Reset trail for new shooting star

      this.shootingStars.push(star);
    }

    private findOrbitContainer(): void {
      // Try specific selectors in order of preference
      const selectors = ['.orbit-container'];

      for (const selector of selectors) {
        const element = document.querySelector(selector);
        if (element && element.getBoundingClientRect().width > 0) {
          this.orbitContainer = element;
          this.updateOrbitRect();
          break;
        }
      }
    }

    private updateOrbitRect(): void {
      if (this.orbitContainer) {
        this.orbitRect = this.orbitContainer.getBoundingClientRect();
      }
    }

    private getGravityCoordinates(): { x: number; y: number; width: number; height: number } {
      const now = performance.now();

      // Update cache less frequently but smoothly interpolate
      if (this.gravityCache && now - this.gravityCache.lastUpdate < 50) {
        return this.gravityCache.coords;
      }

      // Only update if orbit container exists
      if (this.orbitContainer) {
        this.updateOrbitRect();
      }

      let coords: { x: number; y: number; width: number; height: number };

      if (this.orbitRect && this.orbitContainer) {
        // Get coordinates relative to viewport
        const rect = this.orbitContainer.getBoundingClientRect();
        coords = {
          x: rect.left + rect.width / 2,
          y: rect.top + rect.height / 2,
          width: rect.width,
          height: rect.height,
        };
      } else {
        // Fallback to center if no orbit container
        coords = {
          x: this.width / 2,
          y: this.height / 2,
          width: Math.min(this.width, this.height) * 0.2,
          height: Math.min(this.width, this.height) * 0.2,
        };
      }

      this.gravityCache = { coords, lastUpdate: now };
      return coords;
    }

    private applyGravity(star: ShootingStar, deltaTime: number): void {
      if (!this.config.gravity.enabled || !this.orbitContainer) return;

      const gravity = this.getGravityCoordinates();
      const dx = gravity.x - star.x;
      const dy = gravity.y - star.y;
      const distanceSquared = dx * dx + dy * dy;
      const distance = Math.sqrt(distanceSquared);

      const minDistance = Math.min(gravity.width, gravity.height) / 4;
      if (distance < minDistance) return;

      const orbitRadius = Math.max(gravity.width, gravity.height) / 2;
      const strengthMultiplier = distance < orbitRadius ? 2 : 1;
      const force = (this.config.gravity.strength * strengthMultiplier) / distanceSquared;
      const normalizedDelta = deltaTime / 16.67;

      const invDistance = 1 / distance;
      const forceX = dx * invDistance * force * normalizedDelta;
      const forceY = dy * invDistance * force * normalizedDelta;

      const cosAngle = Math.cos(star.angle);
      const sinAngle = Math.sin(star.angle);
      const currentVelX = cosAngle * star.speed;
      const currentVelY = sinAngle * star.speed;

      const newVelX = currentVelX + forceX;
      const newVelY = currentVelY + forceY;

      star.angle = Math.atan2(newVelY, newVelX);
      star.speed = Math.sqrt(newVelX * newVelX + newVelY * newVelY);
    }

    private applyMultipleGravitationalLensing(star: Star): { x: number; y: number } {
      let result = { x: star.x, y: star.y };

      // Apply subtle orbit gravity if container exists
      if (this.config.gravity.enabled && this.orbitContainer) {
        const gravityCoords = this.getGravityCoordinates();
        result = this.applyDramaticGravitationalWarp(
          result,
          { x: gravityCoords.x, y: gravityCoords.y },
          2.8, // Balanced effect - noticeable but not excessive
          0.4 // Moderate radius of influence
        );
      }

      // Apply mouse gravity with dramatic effect
      if (
        this.config.mouseGravity.enabled &&
        this.mouseX > 0 &&
        this.mouseY > 0 &&
        this.mouseX < this.width &&
        this.mouseY < this.height
      ) {
        result = this.applyDramaticGravitationalWarp(
          result,
          { x: this.mouseX, y: this.mouseY },
          this.mouseGravityStrength * 1.5, // Moderate mouse effect
          this.mouseGravityRadius // Normal mouse radius
        );
      }

      return result;
    }

    private applyDramaticGravitationalWarp(
      position: { x: number; y: number },
      gravityCenter: { x: number; y: number },
      strength: number,
      maxRadiusRatio: number
    ): { x: number; y: number } {
      const dx = position.x - gravityCenter.x;
      const dy = position.y - gravityCenter.y;
      const distance = Math.sqrt(dx * dx + dy * dy);

      const maxWarpRadius = Math.min(this.width, this.height) * maxRadiusRatio;
      if (distance > maxWarpRadius || distance < 2) {
        return position;
      }

      // Create dramatic gravitational warping effect
      const normalizedDistance = distance / maxWarpRadius;

      // Exponential falloff for more dramatic effect near center
      const falloff = Math.exp(-normalizedDistance * 2) * (1 - normalizedDistance);
      const warpStrength = falloff * strength;

      const angle = Math.atan2(dy, dx);

      // BLACK HOLE ORBITAL MECHANICS - expulsion and rotation
      // Create outward displacement like matter being ejected from accretion disk
      const radialExpulsion = 1 + warpStrength * 0.8; // Push stars outward
      let warpedDistance = distance * radialExpulsion;

      // Steady orbital rotation instead of pulsing
      const time = performance.now() * 0.0002; // Much slower time progression
      const orbitRotation = time * warpStrength * 0.2; // Reduced rotation speed

      // Create stable orbital paths - closer stars orbit faster
      const orbitalSpeed = warpStrength * (1 / Math.max(normalizedDistance, 0.1)) * 0.08; // Much slower orbital speed
      const orbitalAngle = angle + orbitRotation * orbitalSpeed;

      // Minimal distortion - just smooth orbital mechanics
      const distortedAngle = orbitalAngle;

      return {
        x: gravityCenter.x + Math.cos(distortedAngle) * warpedDistance,
        y: gravityCenter.y + Math.sin(distortedAngle) * warpedDistance,
      };
    }

    private updateShootingStars(deltaTime: number): void {
      const padding = 100;

      for (let i = this.shootingStars.length - 1; i >= 0; i--) {
        const star = this.shootingStars[i];

        // Apply gravity first
        this.applyGravity(star, deltaTime);

        // Add current position to trail history
        star.trail.push({
          x: star.x,
          y: star.y,
          opacity: 1,
        });

        // Limit trail length for performance
        if (star.trail.length > star.maxTrailLength) {
          star.trail.shift();
        }

        // Update position
        const distance = (star.speed * deltaTime) / 16.67; // Normalize to 60fps
        star.x += Math.cos(star.angle) * distance;
        star.y += Math.sin(star.angle) * distance;

        for (let i = 0; i < star.trail.length; i++) {
          star.trail[i].opacity = i / star.trail.length;
        }

        // Check if off screen
        if (
          star.x < -padding ||
          star.x > this.width + padding ||
          star.y < -padding ||
          star.y > this.height + padding
        ) {
          star.active = false;
          this.shootingStars.splice(i, 1);
        }
      }

      // Create new shooting star if it's time
      if (this.config.shootingStars.enabled && performance.now() >= this.nextShootingStarTime) {
        this.createShootingStar();
        this.scheduleNextShootingStar();
      }
    }

    private render(): void {
      if (!this.ctx) return;

      const ctx = this.ctx;

      if (this.config.backgroundColor) {
        ctx.fillStyle = this.config.backgroundColor;
        ctx.fillRect(0, 0, this.width, this.height);
      } else {
        ctx.clearRect(0, 0, this.width, this.height);
      }

      if (this.isLoading) {
        this.renderLoadingState(ctx);
        return;
      }

      const fadeAlpha =
        this.fadeInProgress < 1
          ? Math.min(1, (performance.now() - this.loadingStartTime - 500) / 1000)
          : 1;

      if (fadeAlpha <= 0) return;

      const time = performance.now() * 0.001;
      const viewportPadding = 50;

      // Optimize rendering with batching and improved culling
      ctx.fillStyle = this.config.stars.starsColor;

      for (const star of this.stars) {
        // Improved viewport culling
        if (
          star.x < -viewportPadding ||
          star.x > this.width + viewportPadding ||
          star.y < -viewportPadding ||
          star.y > this.height + viewportPadding
        ) {
          continue;
        }

        // Apply smooth gravitational lensing
        const lensedPosition = this.applyMultipleGravitationalLensing(star);

        // Skip if lensed position is out of bounds
        if (
          lensedPosition.x < -viewportPadding ||
          lensedPosition.x > this.width + viewportPadding ||
          lensedPosition.y < -viewportPadding ||
          lensedPosition.y > this.height + viewportPadding
        ) {
          continue;
        }

        // Calculate star opacity with stable twinkling
        let opacity = star.opacity;
        if (star.twinkleSpeed !== null) {
          // Smoother, less flickery twinkling
          opacity = 0.6 + 0.4 * Math.sin(time / star.twinkleSpeed + star.twinklePhase);
        }

        // Calculate subtle size variation based on gravitational distortion
        const distanceFromOriginal = Math.sqrt(
          (lensedPosition.x - star.x) ** 2 + (lensedPosition.y - star.y) ** 2
        );

        // Balanced gravitational lensing effect - moderate magnification
        const gravitationalMagnification = 1 + distanceFromOriginal * 0.015; // Moderate effect
        const finalRadius = star.radius * Math.min(gravitationalMagnification, 2.0); // Reasonable max magnification

        // Moderate brightness variation
        const lensingBrightness = 1 + distanceFromOriginal * 0.004; // Balanced brightness effect
        const finalOpacity = Math.min(opacity * lensingBrightness, 1) * fadeAlpha;

        // Render star with gravitational effects
        ctx.globalAlpha = finalOpacity;
        ctx.beginPath();
        ctx.arc(lensedPosition.x, lensedPosition.y, finalRadius, 0, Math.PI * 2);
        ctx.fill();
      }

      if (!this.isLoading) {
        ctx.globalAlpha = fadeAlpha;
        for (const star of this.shootingStars) {
          if (!star.active || star.trail.length < 2) continue;

          // Draw curved trail using path history
          ctx.lineWidth = this.config.shootingStars.starHeight;
          ctx.lineCap = 'round';
          ctx.lineJoin = 'round';

          ctx.beginPath();
          ctx.moveTo(star.trail[0].x, star.trail[0].y);

          for (let i = 1; i < star.trail.length; i++) {
            ctx.lineTo(star.trail[i].x, star.trail[i].y);
          }

          const gradient = ctx.createLinearGradient(
            star.trail[0].x,
            star.trail[0].y,
            star.trail[star.trail.length - 1].x,
            star.trail[star.trail.length - 1].y
          );

          gradient.addColorStop(
            0,
            `rgba(${this.trailColors.r}, ${this.trailColors.g}, ${this.trailColors.b}, 0)`
          );
          gradient.addColorStop(
            1,
            `rgba(${this.shootingStarColors.r}, ${this.shootingStarColors.g}, ${this.shootingStarColors.b}, ${star.opacity})`
          );

          ctx.strokeStyle = gradient;
          ctx.stroke();

          const head = star.trail[star.trail.length - 1];
          const headRadius = this.config.shootingStars.starHeight;

          ctx.save();
          ctx.shadowColor = `rgba(${this.shootingStarColors.r}, ${this.shootingStarColors.g}, ${this.shootingStarColors.b}, 0.8)`;
          ctx.shadowBlur = headRadius * 2;
          ctx.fillStyle = `rgba(${this.shootingStarColors.r}, ${this.shootingStarColors.g}, ${this.shootingStarColors.b}, ${star.opacity})`;
          ctx.beginPath();
          ctx.arc(head.x, head.y, headRadius, 0, Math.PI * 2);
          ctx.fill();
          ctx.restore();
        }
      }
    }

    private renderLoadingState(ctx: CanvasRenderingContext2D): void {
      const progress = this.loadingProgress;
      const time = performance.now() * 0.003;
      const centerX = this.width / 2;
      const centerY = this.height / 2;

      // Create cosmic nebula background
      const nebula = ctx.createRadialGradient(
        centerX,
        centerY,
        0,
        centerX,
        centerY,
        Math.min(this.width, this.height) * 0.4
      );
      nebula.addColorStop(0, 'rgba(158, 0, 255, 0.3)');
      nebula.addColorStop(0.4, 'rgba(46, 185, 223, 0.2)');
      nebula.addColorStop(0.7, 'rgba(138, 43, 226, 0.1)');
      nebula.addColorStop(1, 'rgba(0, 0, 0, 0)');

      ctx.fillStyle = nebula;
      ctx.fillRect(0, 0, this.width, this.height);

      // Pulsing central galaxy core
      const coreRadius = 15 + Math.sin(time * 2) * 5;
      const coreGradient = ctx.createRadialGradient(
        centerX,
        centerY,
        0,
        centerX,
        centerY,
        coreRadius
      );
      coreGradient.addColorStop(0, 'rgba(255, 255, 255, 0.9)');
      coreGradient.addColorStop(0.3, 'rgba(158, 0, 255, 0.8)');
      coreGradient.addColorStop(0.7, 'rgba(46, 185, 223, 0.6)');
      coreGradient.addColorStop(1, 'rgba(46, 185, 223, 0)');

      ctx.fillStyle = coreGradient;
      ctx.beginPath();
      ctx.arc(centerX, centerY, coreRadius, 0, Math.PI * 2);
      ctx.fill();

      // Rotating spiral arms with particles
      for (let arm = 0; arm < 3; arm++) {
        const armAngle = (arm / 3) * Math.PI * 2 + time * 0.5;

        for (let i = 0; i < 20; i++) {
          const t = i / 20;
          const spiralAngle = armAngle + t * Math.PI * 4;
          const radius = t * 100 * (0.5 + progress * 0.5);

          const x = centerX + Math.cos(spiralAngle) * radius;
          const y = centerY + Math.sin(spiralAngle) * radius;

          // Particle size varies with distance and progress
          const particleSize = (3 - t * 2) * (0.3 + progress * 0.7);
          const opacity = (1 - t * 0.7) * (0.4 + progress * 0.6);

          // Shimmer effect
          const shimmer = 0.7 + 0.3 * Math.sin(time * 3 + i * 0.5);

          ctx.globalAlpha = opacity * shimmer;

          // Color transition from core to edge
          const hue = t < 0.5 ? `rgba(158, 0, 255, ${opacity})` : `rgba(46, 185, 223, ${opacity})`;
          ctx.fillStyle = hue;

          ctx.beginPath();
          ctx.arc(x, y, particleSize, 0, Math.PI * 2);
          ctx.fill();

          // Add glow effect for larger particles
          if (particleSize > 1.5) {
            ctx.shadowColor = hue;
            ctx.shadowBlur = particleSize * 2;
            ctx.beginPath();
            ctx.arc(x, y, particleSize * 0.5, 0, Math.PI * 2);
            ctx.fill();
            ctx.shadowBlur = 0;
          }
        }
      }

      // Shooting stars during loading
      for (let i = 0; i < 3; i++) {
        const shootTime = (time + i * 2) % 6;
        if (shootTime < 2) {
          const t = shootTime / 2;
          const angle = (i / 3) * Math.PI * 2 + time * 0.2;
          const startRadius = 80;
          const endRadius = 150;

          const currentRadius = startRadius + (endRadius - startRadius) * t;
          const x = centerX + Math.cos(angle) * currentRadius;
          const y = centerY + Math.sin(angle) * currentRadius;

          const opacity = Math.sin(t * Math.PI) * 0.8;
          const trailLength = 20;

          ctx.lineCap = 'round';
          ctx.lineWidth = 2;

          const gradient = ctx.createLinearGradient(
            x - Math.cos(angle) * trailLength,
            y - Math.sin(angle) * trailLength,
            x,
            y
          );
          gradient.addColorStop(0, 'rgba(46, 185, 223, 0)');
          gradient.addColorStop(1, `rgba(46, 185, 223, ${opacity})`);

          ctx.strokeStyle = gradient;
          ctx.beginPath();
          ctx.moveTo(x - Math.cos(angle) * trailLength, y - Math.sin(angle) * trailLength);
          ctx.lineTo(x, y);
          ctx.stroke();
        }
      }

      // Progress indicator as expanding energy ring
      const progressRadius = 120 * progress;
      if (progress > 0.1) {
        ctx.strokeStyle = `rgba(158, 0, 255, ${0.8 * (1 - progress)})`;
        ctx.lineWidth = 3;
        ctx.setLineDash([10, 5]);
        ctx.lineDashOffset = -time * 20;
        ctx.beginPath();
        ctx.arc(centerX, centerY, progressRadius, 0, Math.PI * 2);
        ctx.stroke();
        ctx.setLineDash([]);
      }

      // Floating energy particles
      for (let i = 0; i < 15; i++) {
        const angle = (i / 15) * Math.PI * 2 + time * 0.3;
        const radius = 60 + Math.sin(time * 2 + i) * 20;
        const x = centerX + Math.cos(angle) * radius;
        const y = centerY + Math.sin(angle) * radius;

        const size = 1 + Math.sin(time * 4 + i * 0.7) * 0.5;
        const opacity = 0.6 + Math.sin(time * 3 + i * 0.5) * 0.4;

        ctx.globalAlpha = opacity;
        ctx.fillStyle = i % 2 === 0 ? 'rgba(158, 0, 255, 1)' : 'rgba(46, 185, 223, 1)';
        ctx.beginPath();
        ctx.arc(x, y, size, 0, Math.PI * 2);
        ctx.fill();
      }

      ctx.globalAlpha = 1;
    }

    private renderStatic(): void {
      if (!this.ctx) return;

      // Only fill background if color is set
      // Always show background color first
      if (this.config.backgroundColor) {
        this.ctx.fillStyle = this.config.backgroundColor;
        this.ctx.fillRect(0, 0, this.width, this.height);
      } else {
        this.ctx.clearRect(0, 0, this.width, this.height);
      }

      this.ctx.fillStyle = this.config.stars.starsColor;

      for (const star of this.stars) {
        const lensedPosition = this.applyMultipleGravitationalLensing(star);

        this.ctx.globalAlpha = star.opacity;
        this.ctx.beginPath();
        this.ctx.arc(lensedPosition.x, lensedPosition.y, star.radius, 0, Math.PI * 2);
        this.ctx.fill();
      }
    }

    private animateFrame(): void {
      const currentTime = performance.now();
      const deltaTime = Math.min(currentTime - this.lastTime, 33.33);
      this.lastTime = currentTime;
      this.frameCount++;

      this.updateShootingStars(deltaTime);
      this.render();

      this.animationId = requestAnimationFrame(() => this.animateFrame());
    }

    private handleResize(): void {
      if (this.resizeTimeout) {
        clearTimeout(this.resizeTimeout);
      }

      this.resizeTimeout = window.setTimeout(() => {
        const oldWidth = this.width;
        const oldHeight = this.height;

        this.setupCanvas();

        // Update orbit container position after resize
        this.findOrbitContainer();

        // Reposition stars proportionally instead of regenerating
        const widthRatio = this.width / oldWidth;
        const heightRatio = this.height / oldHeight;

        for (const star of this.stars) {
          star.x *= widthRatio;
          star.y *= heightRatio;
        }

        // Add new stars if canvas grew significantly
        if (this.width * this.height > oldWidth * oldHeight * 1.5) {
          this.initializeStars();
        }
      }, 150);
    }

    disconnectedCallback(): void {
      // Save state before disconnecting
      this.saveStateToStorage();

      // Don't clean up during view transitions
      if (this.isViewTransition()) {
        return;
      }

      if (this.animationId) {
        cancelAnimationFrame(this.animationId);
        this.animationId = null;
      }

      if (this.resizeTimeout) {
        clearTimeout(this.resizeTimeout);
        this.resizeTimeout = null;
      }

      // Clean up event listeners
      window.removeEventListener('resize', this.handleResize.bind(this));
      window.removeEventListener('mousemove', this.handleMouseMove);
      if (this.canvas) {
        this.canvas.removeEventListener('mouseleave', this.handleMouseLeave);
      }

      // Clear global instance if this is the current one
      if (SpaceBackground.globalInstance === this) {
        SpaceBackground.globalInstance = null;
      }
    }

    private handleMouseMove = (event: MouseEvent) => {
      const now = performance.now();
      if (now - this.lastMouseMove < this.MOUSE_THROTTLE) return;

      this.lastMouseMove = now;
      // Since canvas is position: fixed, use clientX/Y directly
      this.mouseX = event.clientX;
      this.mouseY = event.clientY;
    };

    private handleMouseLeave = () => {
      // Move mouse "gravity" off-screen when mouse leaves
      this.mouseX = -1000;
      this.mouseY = -1000;
    };
  }

  // Define the custom element
  if (!customElements.get('space-background')) {
    customElements.define('space-background', SpaceBackground);
  }
</script>

<style>
  space-background {
    /* CRÍTICO: Mínimas propiedades para no interferir con backdrop-filter */
    display: block;
    pointer-events: none;
    /* NO usar position, z-index, o cualquier propiedad que cree stacking context */
    /* El canvas hijo usará position: fixed directamente */
  }

  .space-canvas {
    image-rendering: pixelated;
    image-rendering: -moz-crisp-edges;
    image-rendering: crisp-edges;
    /* CRÍTICO: Canvas debe usar position fixed para ser visible a backdrop-filter */
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    /* CRÍTICO: z-index debe estar por debajo del contenido */
    z-index: -1;
    /* CRÍTICO: Propiedades mínimas para evitar interferencia con backdrop-filter */
    isolation: auto;
    contain: none;
    transform: none;
    filter: none;
    opacity: 1;
    mix-blend-mode: normal;
    /* Evitar propiedades que interfieran con backdrop-filter */
    -webkit-transform: none;
    -webkit-filter: none;
    backface-visibility: visible;
    will-change: auto;
  }

  /* Asegurar que elementos con backdrop-filter puedan acceder al canvas */
  space-background,
  .space-canvas {
    /* Forzar que sean parte del mismo layer de composición */
    will-change: auto;
    contain: none;
  }

  /* Optimización para webkit */
  @supports (-webkit-backdrop-filter: blur(1px)) {
    .space-canvas {
      -webkit-transform: translateZ(0);
      transform: translateZ(0);
    }
  }
</style>
