---
import type { PersonalCard } from '@/types/personal-card';
import { personalCardsData } from '@/data/personal-cards';
import ErrorBoundary from './ErrorBoundary.astro';
import LoadingSpinner from './LoadingSpinner.astro';

// Utility for card styles - simplified and performant
const getCardStyles = (rarity: string, colors?: PersonalCard['colors']) => {
  const rarityStyles = {
    legendary: 'from-yellow-400 via-orange-500 to-red-600',
    epic: 'from-purple-400 via-purple-600 to-indigo-600',
    rare: 'from-blue-400 via-blue-600 to-cyan-600',
    common: 'from-gray-400 via-gray-600 to-gray-700',
  };

  return {
    gradient:
      colors?.border || rarityStyles[rarity as keyof typeof rarityStyles] || rarityStyles.common,
    glow: colors?.glow || '',
    bg: colors?.background || '',
  };
};
---

<div class="overflow-container lazy-carousel" style="width: 100vw; position: relative;" role="region" aria-label="Carrusel de tarjetas personales">
  <!-- Loading placeholder -->
  <div class="carousel-loading" aria-label="Cargando carrusel de tarjetas personales" role="status">
    <div class="max-w-[500px] mx-auto p-4">
      <div class="animate-pulse">
        <LoadingSpinner size="lg" message="Cargando carrusel..." />
      </div>
      <span class="sr-only">Cargando carrusel...</span>
    </div>
  </div>

  <!-- Actual carousel - loaded dynamically -->
  <div class="carousel-wrapper overflow-x-hidden" style="display: none;" role="region" aria-label="Carrusel interactivo de tarjetas personales">
    <div class="carousel-container relative mx-auto w-full max-w-[500px] overflow-visible">
      <div class="swiper carousel" style="padding-top: 10px; padding-bottom: 10px;" role="group" aria-label="Tarjetas deslizables">
        <div class="swiper-wrapper" role="listbox">
          {
            personalCardsData.map((card) => {
              const styles = getCardStyles(card.rarity, card.colors);
              return (
                <div class="swiper-slide" role="option" aria-label={`Tarjeta ${card.title}: ${card.subtitle}`}>
                  <div class="card-flip group relative h-full w-full" tabindex="0" role="button" aria-label={`Voltear tarjeta ${card.title}`}>
                    <div class="card-face">
                      <div
                        class={`relative h-full overflow-x-hidden rounded-xl ring-2 ${styles.glow || 'ring-white/20'}`}
                      >
                        <div
                          class={`absolute inset-0 rounded-xl bg-gradient-to-br ${styles.gradient} p-[2px]`}
                        >
                          <div
                            class={`relative h-full w-full overflow-hidden rounded-xl ${styles.bg || 'bg-gray-900'} bg-[url('https://cdn.moura.ar/bgCardFront.webp')] bg-[length:368px_520px] bg-no-repeat bg-center`}
                          >
                            <div class="shimmer absolute inset-0 opacity-0 z-1 pointer-events-none" />

                            <div class="relative flex h-full flex-col">
                              {/* Flip indicator */}
                              <div
                                class={`absolute ${card.specialTag ? 'top-12 right-2' : 'top-2 right-2'} z-40`}
                              >
                                <div
                                  class={`flip-indicator group/flip relative bg-gradient-to-br ${styles.gradient} p-px rounded-full shadow-sm`}
                                >
                                  <div
                                    class={`${styles.bg || 'bg-gray-900'} rounded-full p-2 backdrop-blur-sm border border-white/5`}
                                  >
                                    <svg
                                      class="h-3 w-3 opacity-50 transition-all duration-500 group-hover/flip:rotate-180 group-hover/flip:opacity-80"
                                      fill="none"
                                      viewBox="0 0 24 24"
                                      stroke="currentColor"
                                    >
                                      <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
                                      />
                                    </svg>
                                  </div>
                                </div>
                              </div>

                              {card.specialTag && (
                                <div class="absolute -top-1 right-0 z-30 translate-x-1">
                                  <div
                                    class={`bg-gradient-to-br ${styles.gradient} p-px rounded-bl-lg rounded-tr-xl`}
                                  >
                                    <div
                                      class={`${styles.bg || 'bg-gray-900'} px-3 py-1 rounded-bl-lg rounded-tr-xl`}
                                    >
                                      <span class="text-xs font-bold uppercase tracking-wider text-white">
                                        {card.specialTag}
                                      </span>
                                    </div>
                                  </div>
                                </div>
                              )}

                              <div class="relative z-20 p-4 sm:p-4 pb-1">
                                <h3 class="text-lg sm:text-lg font-bold text-white">
                                  {card.title}
                                </h3>
                                <p class="text-sm text-gray-300">{card.subtitle}</p>

                                {card.tags && (
                                  <div class="mt-3 sm:mt-3 flex flex-wrap gap-1.5">
                                    {card.tags.map((tag) => (
                                      <span class="rounded-full bg-white/10 px-2 sm:px-2 py-1 sm:py-1 text-[0.6rem] font-medium uppercase tracking-wide text-white backdrop-blur-sm border border-white/10">
                                        {tag}
                                      </span>
                                    ))}
                                  </div>
                                )}
                              </div>

                              <div class="z-20 flex-1 p-4 sm:p-4 pt-2 sm:pt-2">
                                <div class="space-y-2 sm:space-y-2">
                                  <div class="flex items-center gap-2 sm:gap-2">
                                    <div class="flex items-center gap-1">
                                      <div class="h-2 w-2 rounded-full bg-white/30"></div>
                                      <span class="text-xs text-gray-300">
                                        {card.rarity}
                                      </span>
                                    </div>
                                    <div class="flex items-center gap-1">
                                      <div class="h-2 w-2 rounded-full bg-white/30"></div>
                                      <span class="text-xs text-gray-300">
                                        {card.category}
                                      </span>
                                    </div>
                                  </div>
                                  <p class="text-xs text-gray-400 leading-relaxed">
                                    {card.description}
                                  </p>
                                </div>
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              );
            })
          }
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .lazy-carousel {
    min-height: 500px;
  }

  .carousel-loading {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 400px;
  }

  .carousel-loaded .carousel-loading {
    display: none;
  }

  .carousel-loaded .carousel-wrapper {
    display: block !important;
  }

  /* Simplified card styles */
  .card-flip {
    perspective: 1000px;
    width: 280px;
    height: 400px;
    margin: 0 auto;
  }

  .card-face {
    width: 100%;
    height: 100%;
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.6s;
  }

  /* Accessibility improvements */
  .card-flip:focus {
    outline: 2px solid #ecad22;
    outline-offset: 4px;
  }

  .card-flip[aria-pressed="true"] .card-face {
    transform: rotateY(180deg);
  }

  /* Screen reader content */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Reduced motion support */
  @media (prefers-reduced-motion: reduce) {
    .card-face {
      transition: none;
    }
    
    .animate-pulse {
      animation: none;
    }
  }

  @media (max-width: 640px) {
    .card-flip {
      width: 250px;
      height: 350px;
    }
  }
</style>

<script>
  class LazyCarousel {
    private observer!: IntersectionObserver;
    private loaded = false;

    constructor() {
      this.init();
    }

    private init() {
      // Create intersection observer
      this.observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting && !this.loaded) {
              this.loadCarousel();
            }
          });
        },
        {
          root: null,
          rootMargin: '100px',
          threshold: 0.1,
        }
      );

      // Observe the carousel container
      const carouselContainer = document.querySelector('.lazy-carousel');
      if (carouselContainer) {
        this.observer.observe(carouselContainer);
      }
    }

    private async loadCarousel() {
      if (this.loaded) return;
      
      this.loaded = true;
      
      try {
        // Import bundle optimizer
        const { lazyLoadModule } = await import('@/utils/bundleOptimizer');
        
        // Dynamic import of Swiper with optimization
        const [{ default: Swiper }, { EffectCards }] = await Promise.all([
          lazyLoadModule(() => import('swiper'), 'swiper'),
          lazyLoadModule(() => import('swiper/modules'), 'swiper/modules')
        ]);

        // Import CSS with optimization
        await Promise.all([
          lazyLoadModule(() => import('swiper/css'), 'swiper/css'),
          lazyLoadModule(() => import('swiper/css/effect-cards'), 'swiper/css/effect-cards')
        ]);

        // Initialize Swiper
        const isMobile = window.innerWidth <= 640;
        
        new Swiper('.carousel', {
          modules: [EffectCards],
          effect: 'cards',
          grabCursor: true,
          centeredSlides: true,
          slidesPerView: 'auto',
          cardsEffect: {
            perSlideOffset: isMobile ? 5 : 9,
            perSlideRotate: isMobile ? 1 : 3,
            rotate: true,
            slideShadows: true,
          },
          loop: true,
          speed: 300,
          watchOverflow: true,
          preventClicks: true,
          preventClicksPropagation: true,
        });

        // Mark as loaded
        const container = document.querySelector('.lazy-carousel');
        if (container) {
          container.classList.add('carousel-loaded');
        }

        // Initialize card interactions
        this.initCardInteractions();
        
      } catch (error) {
        console.error('Error loading carousel:', error);
      }
    }

    private initCardInteractions() {
      setTimeout(() => {
        const cards = document.querySelectorAll('.card-flip');
        
        cards.forEach((card) => {
          const cardElement = card as HTMLElement;
          let rafId: number;

          // Click handler
          cardElement.addEventListener('click', (e: Event) => {
            const target = e.target as HTMLElement;
            if (target?.closest('a')) return;

            if (rafId) cancelAnimationFrame(rafId);
            
            this.toggleCard(cardElement);
          });

          // Keyboard handler
          cardElement.addEventListener('keydown', (e: KeyboardEvent) => {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              this.toggleCard(cardElement);
            }
          });
        });
      }, 100);
    }

    private toggleCard(cardElement: HTMLElement) {
      const isFlipped = cardElement.getAttribute('aria-pressed') === 'true';
      const newState = !isFlipped;
      
      cardElement.setAttribute('aria-pressed', newState.toString());
      cardElement.classList.toggle('flipped', newState);
      
      // Update aria-label for screen readers
      const title = cardElement.getAttribute('aria-label') || '';
      const action = newState ? 'Presiona para ver el frente' : 'Presiona para ver el reverso';
      cardElement.setAttribute('aria-label', `${title} - ${action}`);
    }
  }

  // Initialize when DOM is ready
  document.addEventListener('DOMContentLoaded', () => {
    new LazyCarousel();
  });
</script>