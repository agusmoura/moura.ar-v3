---
import Layout from '@layouts/Layout.astro';
---

<Layout
  title="Backdrop Filter Test | Moura.ar"
  description="Página de prueba para diagnosticar y arreglar backdrop-filter"
  canonical="https://www.moura.ar/test"
  hideMenu={true}
>
  <main class="min-h-screen relative overflow-hidden">
    <!-- 🎯 FONDO DE PRUEBA - Z-INDEX 1 -->
    <div class="fixed inset-0 z-1 pointer-events-none">
      <!-- Gradiente de fondo fuerte -->
      <div class="absolute inset-0 bg-gradient-to-br from-purple-900 via-blue-900 to-indigo-900">
      </div>

      <!-- Texto gigante con alto contraste -->
      <div class="absolute inset-0 flex items-center justify-center">
        <div
          class="text-9xl md:text-[12rem] font-black text-white/90 select-none leading-none text-center"
        >
          GLASS<br />EFFECT<br />TEST
        </div>
      </div>

      <!-- Elementos decorativos con colores brillantes -->
      <div class="absolute top-20 left-20 w-32 h-32 bg-yellow-400 rounded-full opacity-80"></div>
      <div class="absolute bottom-20 right-20 w-24 h-24 bg-pink-400 rounded-full opacity-80"></div>
      <div class="absolute top-1/2 left-10 w-16 h-16 bg-green-400 rounded-full opacity-80"></div>
      <div class="absolute top-1/4 right-1/4 w-20 h-20 bg-red-400 rounded-full opacity-80"></div>

      <!-- Patrón de líneas -->
      <div
        class="absolute inset-0 opacity-30"
        style="background-image: repeating-linear-gradient(45deg, transparent, transparent 40px, rgba(255,255,255,0.3) 40px, rgba(255,255,255,0.3) 42px);"
      >
      </div>

      <!-- Texto adicional -->
      <div class="absolute top-1/4 left-1/4 text-4xl font-bold text-cyan-300">BACKDROP BLUR</div>
      <div class="absolute bottom-1/4 right-1/4 text-3xl font-bold text-lime-300">
        GLASS MORPHISM
      </div>
    </div>

    <!-- 🔍 CONTENEDOR DE PRUEBAS - Z-INDEX 10 -->
    <div class="relative z-10 min-h-screen p-8 flex flex-col gap-8">
      <!-- Título -->
      <div class="text-center">
        <h1 class="text-4xl font-bold text-white mb-4">🎨 Backdrop Filter Test</h1>
        <p class="text-white/80">Probando diferentes intensidades de backdrop-blur</p>
      </div>

      <!-- Grid de pruebas -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-7xl mx-auto">
        <!-- Test 1: backdrop-blur-sm -->
        <div class="relative p-6 rounded-2xl border border-white/30 bg-white/10 backdrop-blur-sm">
          <h3 class="text-white font-bold text-lg mb-3">backdrop-blur-sm</h3>
          <p class="text-white/90">Blur de 4px - Efecto ligero</p>
          <div class="mt-4 p-3 bg-white/20 rounded-lg">
            <p class="text-white/80 text-sm">
              El texto detrás debería verse ligeramente desenfocado
            </p>
          </div>
        </div>

        <!-- Test 2: backdrop-blur-md -->
        <div class="relative p-6 rounded-2xl border border-white/30 bg-white/10 backdrop-blur-md">
          <h3 class="text-white font-bold text-lg mb-3">backdrop-blur-md</h3>
          <p class="text-white/90">Blur de 12px - Efecto medio</p>
          <div class="mt-4 p-3 bg-white/20 rounded-lg">
            <p class="text-white/80 text-sm">
              El texto detrás debería verse moderadamente desenfocado
            </p>
          </div>
        </div>

        <!-- Test 3: backdrop-blur-lg -->
        <div class="relative p-6 rounded-2xl border border-white/30 bg-white/10 backdrop-blur-lg">
          <h3 class="text-white font-bold text-lg mb-3">backdrop-blur-lg</h3>
          <p class="text-white/90">Blur de 16px - Efecto fuerte</p>
          <div class="mt-4 p-3 bg-white/20 rounded-lg">
            <p class="text-white/80 text-sm">
              El texto detrás debería verse claramente desenfocado
            </p>
          </div>
        </div>

        <!-- Test 4: backdrop-blur-xl -->
        <div class="relative p-6 rounded-2xl border border-white/30 bg-white/10 backdrop-blur-xl">
          <h3 class="text-white font-bold text-lg mb-3">backdrop-blur-xl</h3>
          <p class="text-white/90">Blur de 24px - Efecto muy fuerte</p>
          <div class="mt-4 p-3 bg-white/20 rounded-lg">
            <p class="text-white/80 text-sm">El texto detrás debería verse muy desenfocado</p>
          </div>
        </div>

        <!-- Test 5: backdrop-blur-2xl -->
        <div class="relative p-6 rounded-2xl border border-white/30 bg-white/10 backdrop-blur-2xl">
          <h3 class="text-white font-bold text-lg mb-3">backdrop-blur-2xl</h3>
          <p class="text-white/90">Blur de 40px - Efecto extremo</p>
          <div class="mt-4 p-3 bg-white/20 rounded-lg">
            <p class="text-white/80 text-sm">
              El texto detrás debería verse extremadamente desenfocado
            </p>
          </div>
        </div>

        <!-- Test 6: backdrop-blur-3xl -->
        <div class="relative p-6 rounded-2xl border border-white/30 bg-white/10 backdrop-blur-3xl">
          <h3 class="text-white font-bold text-lg mb-3">backdrop-blur-3xl</h3>
          <p class="text-white/90">Blur de 64px - Efecto máximo</p>
          <div class="mt-4 p-3 bg-white/20 rounded-lg">
            <p class="text-white/80 text-sm">
              El texto detrás debería estar completamente desenfocado
            </p>
          </div>
        </div>

        <!-- Test 7: CSS Custom -->
        <div
          class="relative p-6 rounded-2xl border border-white/30 bg-white/10"
          style="backdrop-filter: blur(30px); -webkit-backdrop-filter: blur(30px);"
        >
          <h3 class="text-white font-bold text-lg mb-3">CSS Custom</h3>
          <p class="text-white/90">Blur de 30px - Custom CSS</p>
          <div class="mt-4 p-3 bg-white/20 rounded-lg">
            <p class="text-white/80 text-sm">Usando CSS directo para verificar funcionamiento</p>
          </div>
        </div>

        <!-- Test 8: Saturate + Blur -->
        <div
          class="relative p-6 rounded-2xl border border-white/30 bg-white/10 backdrop-blur-xl backdrop-saturate-150"
        >
          <h3 class="text-white font-bold text-lg mb-3">Blur + Saturate</h3>
          <p class="text-white/90">Blur 24px + Saturate 150%</p>
          <div class="mt-4 p-3 bg-white/20 rounded-lg">
            <p class="text-white/80 text-sm">Combinación de blur y saturación</p>
          </div>
        </div>

        <!-- Test 9: Sin backdrop-filter -->
        <div class="relative p-6 rounded-2xl border border-white/30 bg-white/10">
          <h3 class="text-white font-bold text-lg mb-3">Sin backdrop-filter</h3>
          <p class="text-white/90">Control - Sin efecto</p>
          <div class="mt-4 p-3 bg-white/20 rounded-lg">
            <p class="text-white/80 text-sm">El texto detrás se ve completamente nítido</p>
          </div>
        </div>
      </div>

      <!-- Diagnóstico -->
      <div
        class="max-w-4xl mx-auto mt-8 p-6 rounded-2xl border border-white/30 bg-white/5 backdrop-blur-lg"
      >
        <h2 class="text-2xl font-bold text-white mb-4">🔍 Diagnóstico</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <h3 class="font-bold text-white/90 mb-2">¿Qué debería pasar?</h3>
            <ul class="text-white/80 text-sm space-y-1">
              <li>✅ El texto gigante "GLASS EFFECT TEST" debe verse desenfocado</li>
              <li>✅ Los círculos de colores deben verse borrosos</li>
              <li>✅ El patrón de líneas debe verse difuso</li>
              <li>✅ Mayor blur = menos definición del fondo</li>
            </ul>
          </div>
          <div>
            <h3 class="font-bold text-white/90 mb-2">Si no funciona:</h3>
            <ul class="text-white/80 text-sm space-y-1">
              <li>🔴 Problema con stacking context</li>
              <li>🔴 Backdrop-filter no soportado</li>
              <li>🔴 CSS no se aplica correctamente</li>
              <li>🔴 Z-index mal configurado</li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- Script de diagnóstico -->
    <script>
      // Detectar soporte para backdrop-filter
      function checkBackdropSupport() {
        const testElement = document.createElement('div');
        testElement.style.backdropFilter = 'blur(1px)';
        const supports = testElement.style.backdropFilter === 'blur(1px)';

        const testElementWebkit = document.createElement('div');
        (testElementWebkit.style as any)['-webkit-backdrop-filter'] = 'blur(1px)';
        const supportsWebkit =
          (testElementWebkit.style as any)['-webkit-backdrop-filter'] === 'blur(1px)';

        console.log('🔍 Backdrop Filter Support:', { supports, supportsWebkit });

        return supports || supportsWebkit;
      }

      // Ejecutar diagnóstico
      document.addEventListener('DOMContentLoaded', () => {
        const supported = checkBackdropSupport();

        if (!supported) {
          console.warn('⚠️ Backdrop-filter no soportado en este navegador');
          document.body.style.setProperty('--backdrop-support', 'false');
        } else {
          console.log('✅ Backdrop-filter soportado');
          document.body.style.setProperty('--backdrop-support', 'true');
        }
      });
    </script>
  </main>
</Layout>

<style>
  /* Forzar stacking context correcto */
  main {
    position: relative;
    z-index: 0;
  }

  /* Asegurar que el fondo esté detrás */
  main > div:first-child {
    position: fixed;
    z-index: 1;
  }

  /* Asegurar que el contenido esté encima */
  main > div:last-child {
    position: relative;
    z-index: 10;
  }

  /* Clase de respaldo si backdrop-filter no funciona */
  @supports not (backdrop-filter: blur(1px)) {
    .backdrop-blur-sm,
    .backdrop-blur-md,
    .backdrop-blur-lg,
    .backdrop-blur-xl,
    .backdrop-blur-2xl,
    .backdrop-blur-3xl {
      background-color: rgba(255, 255, 255, 0.3) !important;
    }
  }
</style>
