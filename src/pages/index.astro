---
import About from '@components/sections/About.astro';
import Contact from '@components/sections/Contact.astro';
import Hero from '@components/sections/Hero.astro';
import Projects from '@components/sections/Projects.astro';
import Layout from '@layouts/Layout.astro';
import UmamiTracker from '@components/analytics/UmamiTracker.astro';
---

<Layout
  title="Agustin Mouriño | Desarrollador Full-Stack & Diseñador UX/UI"
  description="Desarrollador de software y diseñador gráfico interdisciplinario. Fusiono código elegante, arte ancestral y astronomía para crear soluciones atemporales. Explora proyectos, reflexiones filosóficas y mi viaje entre lo técnico y lo eterno. 🌌✨"
  canonical="https://www.moura.ar"
>
  <div
    class="container mx-auto px-4 pt-20 pb-16 max-w-7xl flex flex-col items-center justify-between"
  >
    <!-- <HeroAlt /> -->
    <Hero />
    <About />
    <Projects />
    <Contact />
    
    <!-- Page-specific analytics tracking -->
    {import.meta.env.NODE_ENV === 'production' && (
      <UmamiTracker 
        pageEvents={[
          { event: 'Homepage View', data: { version: '3.0', sections: 'hero,about,projects,contact' } }
        ]}
      />
    )}
  </div>
</Layout>
